{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skat-ai/game_shortening.schema.json",
  "title": "skat-ai game shortening input",
  "oneOf": [
    {
      "$ref": "#/$defs/declarer_concession"
    },
    {
      "$ref": "#/$defs/defender_concession"
    },
    {
      "$ref": "#/$defs/declarer_card_exposure"
    }
  ],
  "$defs": {
    "declarer_concession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "declarer_hand_cards_remaining",
        "defender_consent"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "kind": {
          "const": "declarer_concession"
        },
        "declarer_hand_cards_remaining": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "defender_consent": {
          "$ref": "#/$defs/defender_consent"
        }
      }
    },
    "defender_consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "consenting_defender_count"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_required", "granted"]
        },
        "consenting_defender_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        }
      }
    },
    "defender_concession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "conceding_player",
        "concession_form"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "kind": {
          "const": "defender_concession"
        },
        "conceding_player": {
          "type": "string",
          "enum": ["me", "left", "right"]
        },
        "concession_form": {
          "type": "string",
          "enum": [
            "explicit_verbal",
            "adjudicated_unambiguous_conduct"
          ]
        }
      }
    },
    "declarer_card_exposure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "exposure",
        "claimed_play_level",
        "defender_responses"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "kind": {"const": "declarer_card_exposure"},
        "exposure": {"$ref": "#/$defs/declarer_card_exposure_details"},
        "claimed_play_level": {
          "type": "string",
          "enum": ["simple", "schneider", "schwarz"]
        },
        "defender_responses": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"$ref": "#/$defs/defender_exposure_response"}
        }
      }
    },
    "declarer_card_exposure_details": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["form", "exposed_cards"],
          "properties": {
            "form": {"const": "laid_open"},
            "exposed_cards": {"$ref": "#/$defs/exposed_cards"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["form", "shown_to_player", "exposed_cards"],
          "properties": {
            "form": {"const": "shown_to_defender"},
            "shown_to_player": {
              "type": "string",
              "enum": ["me", "left", "right"]
            },
            "exposed_cards": {"$ref": "#/$defs/exposed_cards"}
          }
        }
      ]
    },
    "exposed_cards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[CSHD](A|10|K|Q|J|9|8|7)$"
      }
    },
    "defender_exposure_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player", "response", "form"],
      "properties": {
        "player": {
          "type": "string",
          "enum": ["me", "left", "right"]
        },
        "response": {"const": "accept"},
        "form": {
          "type": "string",
          "enum": ["explicit", "unambiguous_conduct"]
        }
      }
    }
  }
}
