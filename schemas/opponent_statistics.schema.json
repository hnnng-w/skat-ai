{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skat-ai/opponent_statistics.schema.json",
  "title": "skat-ai opponent statistics input version 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "records"],
  "properties": {
    "schema_version": {"const": 1},
    "records": {
      "type": "array",
      "items": {"$ref": "#/$defs/record"}
    }
  },
  "$defs": {
    "non_padded_string": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\s)(?:[\\s\\S]*\\S)?$"
    },
    "percentage_points": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_name", "captured_at"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": ["online_platform", "manual_entry", "historical_games"]
        },
        "source_name": {"$ref": "#/$defs/non_padded_string"},
        "source_player_id": {"$ref": "#/$defs/non_padded_string"},
        "captured_at": {
          "allOf": [
            {"$ref": "#/$defs/non_padded_string"},
            {"type": "string", "format": "date-time"}
          ]
        },
        "notes": {"$ref": "#/$defs/non_padded_string"},
        "historical_aggregation": {"$ref": "#/$defs/historical_aggregation"}
      },
      "allOf": [
        {
          "if": {
            "properties": {"source_type": {"const": "historical_games"}}
          },
          "then": {
            "required": ["source_player_id", "historical_aggregation"]
          },
          "else": {
            "not": {"required": ["historical_aggregation"]}
          }
        }
      ]
    },
    "historical_aggregation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aggregation_version",
        "dataset_id",
        "dataset_version",
        "included_partitions",
        "source_record_ids",
        "source_game_ids",
        "first_played_at",
        "last_played_at"
      ],
      "properties": {
        "aggregation_version": {"const": 1},
        "dataset_id": {"$ref": "#/$defs/non_padded_string"},
        "dataset_version": {"$ref": "#/$defs/non_padded_string"},
        "included_partitions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {"enum": ["train", "validation", "test"]}
        },
        "source_record_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_padded_string"}
        },
        "source_game_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/non_padded_string"}
        },
        "first_played_at": {
          "allOf": [
            {"$ref": "#/$defs/non_padded_string"},
            {"type": "string", "format": "date-time"}
          ]
        },
        "last_played_at": {
          "allOf": [
            {"$ref": "#/$defs/non_padded_string"},
            {"type": "string", "format": "date-time"}
          ]
        }
      }
    },
    "statistics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "solo_games_played_percent",
        "solo_games_won_percent",
        "solo_hand_percent",
        "suit_games_percent",
        "grand_games_percent",
        "null_games_percent",
        "defender_games_played_percent",
        "defender_games_won_percent"
      ],
      "properties": {
        "solo_games_played_percent": {"$ref": "#/$defs/percentage_points"},
        "solo_games_won_percent": {"$ref": "#/$defs/percentage_points"},
        "solo_hand_percent": {"$ref": "#/$defs/percentage_points"},
        "suit_games_percent": {"$ref": "#/$defs/percentage_points"},
        "grand_games_percent": {"$ref": "#/$defs/percentage_points"},
        "null_games_percent": {"$ref": "#/$defs/percentage_points"},
        "defender_games_played_percent": {"$ref": "#/$defs/percentage_points"},
        "defender_games_won_percent": {"$ref": "#/$defs/percentage_points"}
      }
    },
    "exact_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "solo_games_played",
        "solo_games_won",
        "solo_hand_games",
        "suit_games",
        "grand_games",
        "null_games",
        "defender_games_played",
        "defender_games_won"
      ],
      "properties": {
        "solo_games_played": {"type": "integer", "minimum": 0},
        "solo_games_won": {"type": "integer", "minimum": 0},
        "solo_hand_games": {"type": "integer", "minimum": 0},
        "suit_games": {"type": "integer", "minimum": 0},
        "grand_games": {"type": "integer", "minimum": 0},
        "null_games": {"type": "integer", "minimum": 0},
        "defender_games_played": {"type": "integer", "minimum": 0},
        "defender_games_won": {"type": "integer", "minimum": 0}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player_id", "source", "games_played", "statistics"],
      "properties": {
        "player_id": {"$ref": "#/$defs/non_padded_string"},
        "player_label": {"$ref": "#/$defs/non_padded_string"},
        "source": {"$ref": "#/$defs/source"},
        "games_played": {"type": "integer", "minimum": 1},
        "statistics": {"$ref": "#/$defs/statistics"},
        "exact_counts": {"$ref": "#/$defs/exact_counts"}
      }
    }
  }
}
