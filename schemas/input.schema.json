{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skat-ai/input.schema.json",
  "title": "skat-ai input position",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "game_type",
    "player_role",
    "player_position",
    "trick_leader",
    "hand",
    "current_trick",
    "played_cards",
    "completed_tricks",
    "declarer_points",
    "defender_points",
    "next_player",
    "skat",
    "left_hand_size",
    "right_hand_size",
    "sample_count",
    "random_seed",
    "use_basic_opponent_strategy"
  ],
  "not": {
    "required": ["list_performance_input", "list_game_contributions"]
  },
  "allOf": [
    {
      "if": {
        "required": ["list_performance_input"]
      },
      "then": {
        "required": ["performance_rating_system"],
        "properties": {
          "performance_rating_system": {
            "const": "isko_list"
          }
        }
      }
    },
    {
      "if": {
        "required": ["list_game_contributions"]
      },
      "then": {
        "required": ["performance_rating_system"],
        "properties": {
          "performance_rating_system": {
            "const": "isko_list"
          }
        }
      }
    }
  ],
  "properties": {
    "game_type": {
      "type": "string",
      "enum": ["clubs", "spades", "hearts", "diamonds", "grand", "null"]
    },
    "left_opponent_lead_policy": {
      "type": "string"
    },
    "left_opponent_response_policy": {
      "type": "string"
    },
    "right_opponent_lead_policy": {
      "type": "string"
    },
    "right_opponent_response_policy": {
      "type": "string"
    },
    "player_role": {
      "type": "string",
      "enum": ["declarer", "defender", "unknown"]
    },
    "player_position": {
      "type": "string",
      "enum": ["forehand", "middlehand", "rearhand", "unknown"]
    },
    "trick_leader": {
      "$ref": "#/$defs/player"
    },
    "next_player": {
      "$ref": "#/$defs/player"
    },
    "hand": {
      "$ref": "#/$defs/card_array",
      "maxItems": 10,
      "uniqueItems": true
    },
    "current_trick": {
      "$ref": "#/$defs/card_array",
      "maxItems": 2,
      "uniqueItems": true
    },
    "actual_card_played": {
      "$ref": "#/$defs/card"
    },
    "played_cards": {
      "$ref": "#/$defs/card_array",
      "uniqueItems": true
    },
    "skat": {
      "$ref": "#/$defs/card_array",
      "maxItems": 2,
      "uniqueItems": true
    },
    "completed_tricks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/completed_trick"
      }
    },
    "declarer_points": {
      "$ref": "#/$defs/card_points"
    },
    "defender_points": {
      "$ref": "#/$defs/card_points"
    },
    "left_hand_size": {
      "$ref": "#/$defs/hand_size"
    },
    "right_hand_size": {
      "$ref": "#/$defs/hand_size"
    },
    "sample_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100000
    },
    "random_seed": {
      "type": "integer"
    },
    "use_basic_opponent_strategy": {
      "type": "boolean"
    },

    "hand_game": {
      "type": "boolean"
    },
    "ouvert": {
      "type": "boolean"
    },
    "schneider_announced": {
      "type": "boolean"
    },
    "schwarz_announced": {
      "type": "boolean"
    },
    "matadors": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "bid_value": {
      "type": ["integer", "null"],
      "minimum": 1
    },

    "analysis_mode": {
      "type": "string",
      "enum": ["live_decision", "post_game_review"]
    },
    "skat_visibility": {
      "type": "string",
      "enum": ["unknown", "known_post_game"]
    },
    "game_end_reason": {
      "type": "string",
      "enum": [
        "not_ended",
        "normal_completion",
        "declarer_claimed_remaining_tricks",
        "declarer_conceded_remaining_tricks",
        "defenders_conceded_remaining_tricks"
      ]
    },

    "opponent_lead_policy": {
      "type": "string"
    },
    "opponent_response_policy": {
      "type": "string"
    },
    "opponent_policy_preset": {
      "type": "string"
    },
    "use_profile_presets": {
      "type": "boolean"
    },
    "performance_rating_system": {
      "type": ["string", "null"],
      "enum": ["placeholder", "isko_list", null]
    },
    "list_performance_input": {
      "$ref": "#/$defs/list_performance_input"
    },
    "list_game_contributions": {
      "$ref": "#/$defs/list_game_contributions"
    }
  },
  "$defs": {
    "player": {
      "type": "string",
      "enum": ["me", "left", "right", "unknown"]
    },
    "card": {
      "type": "string",
      "pattern": "^[CSHD](A|10|K|Q|J|9|8|7)$"
    },
    "card_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/card"
      }
    },
    "card_points": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120
    },
    "hand_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "positive_integer": {
      "type": "integer",
      "minimum": 1
    },
    "winner_role": {
      "type": "string",
      "enum": ["declarer", "defenders", "unknown"]
    },
    "list_performance_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "player_game_points",
        "own_games_won",
        "own_games_lost",
        "other_players_lost_games"
      ],
      "properties": {
        "player_game_points": {
          "type": "integer"
        },
        "own_games_won": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "own_games_lost": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "other_players_lost_games": {
          "$ref": "#/$defs/non_negative_integer"
        }
      }
    },
    "list_game_contributions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/list_game_contribution"
      }
    },
    "list_game_contribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player_role", "game_outcome", "settlement_score"],
      "properties": {
        "player_role": {
          "type": "string",
          "enum": ["declarer", "defender"]
        },
        "game_outcome": {
          "type": "string",
          "enum": ["declarer_win", "declarer_loss"]
        },
        "settlement_score": {
          "type": "integer"
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["game_outcome"],
            "properties": {
              "game_outcome": {
                "const": "declarer_win"
              }
            }
          },
          "then": {
            "properties": {
              "settlement_score": {
                "minimum": 1
              }
            }
          }
        },
        {
          "if": {
            "required": ["game_outcome"],
            "properties": {
              "game_outcome": {
                "const": "declarer_loss"
              }
            }
          },
          "then": {
            "properties": {
              "settlement_score": {
                "maximum": -1
              }
            }
          }
        }
      ]
    },
    "completed_trick": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cards"],
      "properties": {
        "cards": {
          "$ref": "#/$defs/card_array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true
        },
        "players": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/player"
          },
          "minItems": 3,
          "maxItems": 3
        },
        "winner_role": {
          "$ref": "#/$defs/winner_role"
        },
        "winner_player": {
          "$ref": "#/$defs/player"
        }
      }
    }
  }
}
