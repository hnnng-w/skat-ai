{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skat-ai/output.schema.json",
  "title": "skat-ai output result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "input_file",
    "position",
    "settings",
    "analysis_metadata",
    "game_declaration",
    "game_value_summary",
    "overbid_summary",
    "legal_cards",
    "analysis_report",
    "score_summary",
    "game_result_summary",
    "adjusted_game_result_summary",
    "final_settlement_summary",
    "performance_rating_summary",
    "recommendation",
    "information_policy_summary",
    "post_game_review_summary",
    "opponent_policy_settings",
    "left_opponent_policy_settings",
    "right_opponent_policy_settings",
    "profile_preset_settings"
  ],
  "properties": {
    "input_file": {
      "type": "string"
    },
    "position": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "declarer_player": {
          "$ref": "#/$defs/player"
        }
      }
    },
    "settings": {
      "type": "object"
    },
    "opponent_policy_settings": {
      "$ref": "#/$defs/opponent_policy_settings"
    },
    "left_opponent_policy_settings": {
      "$ref": "#/$defs/opponent_policy_settings"
    },
    "right_opponent_policy_settings": {
      "$ref": "#/$defs/opponent_policy_settings"
    },
    "profile_preset_settings": {
      "$ref": "#/$defs/profile_preset_settings"
    },
    "analysis_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "information_policy_summary": {
      "$ref": "#/$defs/information_policy_summary"
    },
    "post_game_review_summary": {
      "$ref": "#/$defs/post_game_review_summary"
    },
    "game_declaration": {
      "$ref": "#/$defs/game_declaration"
    },
    "game_value_summary": {
      "$ref": "#/$defs/game_value_summary"
    },
    "overbid_summary": {
      "$ref": "#/$defs/overbid_summary"
    },
    "legal_cards": {
      "$ref": "#/$defs/card_array"
    },
    "analysis_report": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analysis_report_item"
      }
    },
    "strategic_summary": {
      "type": "string"
    },
    "score_summary": {
      "$ref": "#/$defs/score_summary"
    },
    "game_result_summary": {
      "$ref": "#/$defs/game_result_summary"
    },
    "adjusted_game_result_summary": {
      "$ref": "#/$defs/adjusted_game_result_summary"
    },
    "final_settlement_summary": {
      "$ref": "#/$defs/final_settlement_summary"
    },
    "performance_rating_summary": {
      "$ref": "#/$defs/performance_rating_summary"
    },
    "list_performance_summary": {
      "$ref": "#/$defs/list_performance_summary"
    },
    "recommendation": {
      "$ref": "#/$defs/recommendation"
    },
    "multi_step_result": {
      "$ref": "#/$defs/multi_step_result"
    },
    "policy_comparison_result": {
      "$ref": "#/$defs/policy_comparison_result"
    }
  },
  "$defs": {
    "card": {
      "type": "string",
      "pattern": "^[CSHD](A|10|K|Q|J|9|8|7)$"
    },
    "card_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/card"
      }
    },
    "player": {
      "type": "string",
      "enum": ["me", "left", "right", "unknown"]
    },
    "nullable_integer": {
      "type": ["integer", "null"]
    },
    "nullable_number": {
      "type": ["number", "null"]
    },
    "nullable_boolean": {
      "type": ["boolean", "null"]
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "game_type": {
      "type": "string",
      "enum": ["clubs", "spades", "hearts", "diamonds", "grand", "null"]
    },
    "player_role": {
      "type": "string",
      "enum": ["declarer", "defender", "unknown"]
    },
    "player_position": {
      "type": "string",
      "enum": ["forehand", "middlehand", "rearhand", "unknown"]
    },
    "trick_player": {
      "type": "string",
      "enum": ["me", "left", "right", "unknown"]
    },
    "winner_role": {
      "type": "string",
      "enum": ["declarer", "defenders"]
    },
    "opponent_card_policy": {
      "type": "string",
      "enum": [
        "lowest_point",
        "highest_point",
        "random_legal",
        "basic_trick_play",
        "basic_defender_response",
        "basic_defender_lead"
      ]
    },
    "card_selection_policy": {
      "type": "string",
      "enum": [
        "first_legal",
        "lowest_point",
        "highest_point",
        "highest_expected_value"
      ]
    },
    "game_end_reason": {
      "type": "string",
      "enum": [
        "not_ended",
        "normal_completion",
        "declarer_claimed_remaining_tricks",
        "declarer_conceded_remaining_tricks",
        "defenders_conceded_remaining_tricks"
      ]
    },
    "overbid_status": {
      "type": "string",
      "enum": [
        "unknown",
        "unknown_bid_value",
        "unknown_game_value",
        "not_overbid",
        "overbid"
      ]
    },
    "multi_step_stop_reason": {
      "type": "string",
      "enum": [
        "Player has no cards left.",
        "Game is already complete.",
        "Requested step count reached.",
        "unsupported_turn_phase"
      ]
    },
    "profile_preset_settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["use_profile_presets"],
      "properties": {
        "use_profile_presets": {
          "type": "boolean"
        }
      }
    },
    "game_declaration": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "game_type",
        "hand_game",
        "ouvert",
        "schneider_announced",
        "schwarz_announced",
        "matadors",
        "bid_value"
      ],
      "properties": {
        "game_type": {
          "$ref": "#/$defs/game_type"
        },
        "hand_game": {
          "type": "boolean"
        },
        "ouvert": {
          "type": "boolean"
        },
        "schneider_announced": {
          "type": "boolean"
        },
        "schwarz_announced": {
          "type": "boolean"
        },
        "matadors": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "bid_value": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "opponent_policy_settings": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "opponent_lead_policy",
        "opponent_response_policy"
      ],
      "properties": {
        "opponent_lead_policy": {
          "$ref": "#/$defs/opponent_card_policy"
        },
        "opponent_response_policy": {
          "$ref": "#/$defs/opponent_card_policy"
        }
      }
    },
    "game_value_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "game_type",
        "is_null_game",
        "base_value",
        "game_level",
        "game_value",
        "details"
      ],
      "properties": {
        "game_type": {
          "$ref": "#/$defs/game_type"
        },
        "is_null_game": {
          "type": "boolean"
        },
        "base_value": {
          "$ref": "#/$defs/nullable_integer"
        },
        "game_level": {
          "$ref": "#/$defs/nullable_integer"
        },
        "game_value": {
          "$ref": "#/$defs/nullable_integer"
        },
        "details": {
          "type": "object"
        }
      }
    },
    "overbid_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "bid_value",
        "game_value",
        "is_overbid",
        "margin",
        "required_game_value",
        "status"
      ],
      "properties": {
        "bid_value": {
          "$ref": "#/$defs/nullable_integer"
        },
        "game_value": {
          "$ref": "#/$defs/nullable_integer"
        },
        "is_overbid": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "margin": {
          "$ref": "#/$defs/nullable_integer"
        },
        "required_game_value": {
          "$ref": "#/$defs/nullable_integer"
        },
        "status": {
          "$ref": "#/$defs/overbid_status"
        }
      }
    },
    "analysis_report_item": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "card",
        "win_rate",
        "average_trick_points",
        "average_points_won",
        "average_points_lost",
        "expected_point_swing",
        "is_recommended"
      ],
      "properties": {
        "card": {
          "$ref": "#/$defs/card"
        },
        "win_rate": {
          "type": "number"
        },
        "average_trick_points": {
          "type": "number"
        },
        "average_points_won": {
          "type": "number"
        },
        "average_points_lost": {
          "type": "number"
        },
        "expected_point_swing": {
          "type": "number"
        },
        "is_recommended": {
          "type": "boolean"
        }
      }
    },
    "score_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "explicit_declarer_points",
        "explicit_defender_points",
        "completed_trick_declarer_points",
        "completed_trick_defender_points",
        "total_declarer_points",
        "total_defender_points"
      ],
      "properties": {
        "explicit_declarer_points": {
          "type": "integer"
        },
        "explicit_defender_points": {
          "type": "integer"
        },
        "completed_trick_declarer_points": {
          "type": "integer"
        },
        "completed_trick_defender_points": {
          "type": "integer"
        },
        "total_declarer_points": {
          "type": "integer"
        },
        "total_defender_points": {
          "type": "integer"
        }
      }
    },
    "game_result_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "declarer_points",
        "defender_points",
        "points_remaining",
        "is_complete",
        "winner"
      ],
      "properties": {
        "declarer_points": {
          "type": "integer"
        },
        "defender_points": {
          "type": "integer"
        },
        "points_remaining": {
          "type": "integer"
        },
        "is_complete": {
          "type": "boolean"
        },
        "winner": {
          "type": "string",
          "enum": ["declarer", "defenders", "undecided"]
        }
      }
    },
    "adjusted_game_result_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "declarer_points",
        "defender_points",
        "points_remaining",
        "is_complete",
        "winner",
        "game_end_reason",
        "remaining_points_recipient",
        "remaining_points_assigned"
      ],
      "properties": {
        "declarer_points": {
          "type": "integer"
        },
        "defender_points": {
          "type": "integer"
        },
        "points_remaining": {
          "type": "integer"
        },
        "is_complete": {
          "type": "boolean"
        },
        "winner": {
          "type": "string",
          "enum": ["declarer", "defenders", "undecided"]
        },
        "game_end_reason": {
          "$ref": "#/$defs/game_end_reason"
        },
        "remaining_points_recipient": {
          "type": ["string", "null"],
          "enum": ["declarer", "defenders", null]
        },
        "remaining_points_assigned": {
          "type": "integer"
        }
      }
    },
    "final_settlement_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "is_complete",
        "missing_inputs",
        "declarer_won_by_card_points",
        "winner",
        "game_value",
        "effective_game_value",
        "bid_value",
        "settlement_score",
        "is_loss",
        "is_overbid",
        "overbid_margin",
        "overbid_status",
        "overbid_required_game_value"
      ],
      "properties": {
        "is_complete": {
          "type": "boolean"
        },
        "missing_inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "declarer_won_by_card_points": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "winner": {
          "type": ["string", "null"],
          "enum": ["declarer", "defenders", null]
        },
        "game_value": {
          "$ref": "#/$defs/nullable_integer"
        },
        "effective_game_value": {
          "$ref": "#/$defs/nullable_integer"
        },
        "bid_value": {
          "$ref": "#/$defs/nullable_integer"
        },
        "settlement_score": {
          "$ref": "#/$defs/nullable_integer"
        },
        "is_loss": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "is_overbid": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "overbid_margin": {
          "$ref": "#/$defs/nullable_integer"
        },
        "overbid_status": {
          "$ref": "#/$defs/overbid_status"
        },
        "overbid_required_game_value": {
          "$ref": "#/$defs/nullable_integer"
        }
      }
    },
    "performance_rating_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "is_implemented",
        "is_partially_implemented",
        "implemented_scope",
        "unsupported_scope",
        "rating_system",
        "table_player_count",
        "basis",
        "game_outcome",
        "settlement_score",
        "rating_score",
        "declarer_rating_score",
        "declarer_rating_points",
        "counterparty_rating_points",
        "defender_rating_points",
        "unsupported_reason"
      ],
      "properties": {
        "is_implemented": {
          "type": "boolean"
        },
        "is_partially_implemented": {
          "type": "boolean"
        },
        "implemented_scope": {
          "type": ["string", "null"]
        },
        "unsupported_scope": {
          "type": "string"
        },
        "rating_system": {
          "type": ["string", "null"]
        },
        "table_player_count": {
          "type": "integer"
        },
        "basis": {
          "type": "string"
        },
        "game_outcome": {
          "type": "string",
          "enum": ["incomplete", "declarer_win", "declarer_loss", "unknown"]
        },
        "settlement_score": {
          "$ref": "#/$defs/nullable_integer"
        },
        "rating_score": {
          "$ref": "#/$defs/nullable_integer"
        },
        "declarer_rating_score": {
          "$ref": "#/$defs/nullable_integer"
        },
        "declarer_rating_points": {
          "$ref": "#/$defs/nullable_integer"
        },
        "counterparty_rating_points": {
          "$ref": "#/$defs/nullable_integer"
        },
        "defender_rating_points": {
          "$ref": "#/$defs/nullable_integer"
        },
        "unsupported_reason": {
          "type": "string"
        }
      }
    },
    "list_performance_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rating_system",
        "basis",
        "table_size",
        "player_game_points",
        "own_games_won",
        "own_games_lost",
        "other_players_lost_games",
        "own_game_bonus_points",
        "opponent_loss_bonus_points",
        "total_performance_points"
      ],
      "properties": {
        "rating_system": {
          "type": "string",
          "enum": ["isko_list"]
        },
        "basis": {
          "type": "string",
          "enum": [
            "aggregated_list_or_series_totals",
            "normalized_game_contributions",
            "local_analysis_results"
          ]
        },
        "table_size": {
          "type": "integer",
          "const": 3
        },
        "player_game_points": {
          "type": "integer"
        },
        "own_games_won": {
          "type": "integer",
          "minimum": 0
        },
        "own_games_lost": {
          "type": "integer",
          "minimum": 0
        },
        "other_players_lost_games": {
          "type": "integer",
          "minimum": 0
        },
        "own_game_bonus_points": {
          "type": "integer"
        },
        "opponent_loss_bonus_points": {
          "type": "integer"
        },
        "total_performance_points": {
          "type": "integer"
        }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": true,
      "required": ["card", "reason"],
      "properties": {
        "card": {
          "type": ["string", "null"]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "information_policy_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis_mode",
        "skat_visibility",
        "game_end_reason",
        "live_information_enforced",
        "known_post_game_skat_allowed",
        "known_skat_cards_allowed",
        "ended_game_allowed",
        "unverifiable_completed_trick_winner_metadata_allowed"
      ],
      "properties": {
        "analysis_mode": {
          "type": "string",
          "enum": ["live_decision", "post_game_review"]
        },
        "skat_visibility": {
          "type": "string",
          "enum": ["unknown", "known_to_declarer", "known_post_game"]
        },
        "game_end_reason": {
          "$ref": "#/$defs/game_end_reason"
        },
        "live_information_enforced": {
          "type": "boolean"
        },
        "known_post_game_skat_allowed": {
          "type": "boolean"
        },
        "known_skat_cards_allowed": {
          "type": "boolean"
        },
        "ended_game_allowed": {
          "type": "boolean"
        },
        "unverifiable_completed_trick_winner_metadata_allowed": {
          "type": "boolean"
        }
      }
    },
    "post_game_review_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_available",
        "reason",
        "actual_card_played",
        "recommended_card",
        "actual_expected_point_swing",
        "recommended_expected_point_swing",
        "expected_point_swing_difference",
        "decision_quality",
        "decision_factors",
        "decision_explanation",
        "actual_card_rank",
        "recommended_card_rank",
        "candidate_count",
        "better_card_count"
      ],
      "properties": {
        "is_available": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "enum": [
            "actual_card_played_not_provided",
            "actual_card_played_provided",
            "immediate_analysis_unavailable"
          ]
        },
        "actual_card_played": {
          "type": ["string", "null"],
          "pattern": "^[CSHD](A|10|K|Q|J|9|8|7)$"
        },
        "recommended_card": {
          "type": ["string", "null"],
          "pattern": "^[CSHD](A|10|K|Q|J|9|8|7)$"
        },
        "actual_expected_point_swing": {
          "$ref": "#/$defs/nullable_number"
        },
        "recommended_expected_point_swing": {
          "$ref": "#/$defs/nullable_number"
        },
        "expected_point_swing_difference": {
          "$ref": "#/$defs/nullable_number"
        },
        "decision_quality": {
          "type": "string",
          "enum": [
            "not_available",
            "optimal",
            "acceptable",
            "suboptimal",
            "mistake"
          ]
        },
        "decision_factors": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "actual_card_played_not_provided",
              "immediate_analysis_unavailable",
              "expected_point_swing_difference_not_available",
              "no_missed_expected_point_swing",
              "lower_expected_point_swing_than_recommendation",
              "small_expected_point_swing_gap",
              "medium_expected_point_swing_gap",
              "large_expected_point_swing_gap",
              "no_missed_null_objective",
              "lower_null_objective_than_recommendation",
              "small_null_objective_gap",
              "medium_null_objective_gap",
              "large_null_objective_gap"
            ]
          }
        },
        "decision_explanation": {
          "type": "string"
        },
        "actual_card_rank": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "recommended_card_rank": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "better_card_count": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "completed_trick": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cards", "winner_role"],
      "properties": {
        "cards": {
          "$ref": "#/$defs/card_array",
          "minItems": 3,
          "maxItems": 3
        },
        "players": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/trick_player"
          },
          "minItems": 3,
          "maxItems": 3
        },
        "winner_role": {
          "$ref": "#/$defs/winner_role"
        },
        "winner_player": {
          "$ref": "#/$defs/trick_player"
        }
      }
    },
    "game_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "game_type",
        "player_role",
        "hand",
        "current_trick",
        "played_cards",
        "skat",
        "player_position",
        "declarer_player",
        "trick_leader",
        "completed_tricks",
        "declarer_points",
        "defender_points",
        "next_player"
      ],
      "properties": {
        "game_type": {
          "$ref": "#/$defs/game_type"
        },
        "player_role": {
          "$ref": "#/$defs/player_role"
        },
        "hand": {
          "$ref": "#/$defs/card_array"
        },
        "current_trick": {
          "$ref": "#/$defs/card_array",
          "maxItems": 2
        },
        "played_cards": {
          "$ref": "#/$defs/card_array"
        },
        "skat": {
          "$ref": "#/$defs/card_array",
          "maxItems": 2
        },
        "player_position": {
          "$ref": "#/$defs/player_position"
        },
        "declarer_player": {
          "$ref": "#/$defs/player"
        },
        "trick_leader": {
          "$ref": "#/$defs/player"
        },
        "completed_tricks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/completed_trick"
          }
        },
        "declarer_points": {
          "$ref": "#/$defs/non_negative_integer"
        },
