{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skat-ai/declarer_card_exposure_output.schema.json",
  "title": "skat-ai accepted declarer card exposure output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "rule_sections",
    "exposure_form",
    "shown_to_player",
    "exposed_cards",
    "exposed_card_count",
    "card_reconciliation",
    "unanimous_defender_acceptance",
    "accepting_defenders",
    "acceptance_forms",
    "claimed_play_level",
    "decision_state_before_shortening",
    "adjudicated_winner",
    "winner_basis",
    "continued_play_required",
    "remaining_points_assigned",
    "settlement_level_policy"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "declarer_card_exposure"},
    "rule_sections": {
      "type": "array",
      "prefixItems": [{"const": "4.4.4"}],
      "items": false,
      "minItems": 1,
      "maxItems": 1
    },
    "exposure_form": {
      "type": "string",
      "enum": ["laid_open", "shown_to_defender"]
    },
    "shown_to_player": {
      "type": ["string", "null"],
      "enum": ["me", "left", "right", null]
    },
    "exposed_cards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[CSHD](A|10|K|Q|J|9|8|7)$"
      }
    },
    "exposed_card_count": {"type": "integer", "minimum": 1, "maximum": 10},
    "card_reconciliation": {
      "type": "string",
      "enum": ["confirmed", "not_verifiable"]
    },
    "unanimous_defender_acceptance": {"const": true},
    "accepting_defenders": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["me", "left", "right"]}
    },
    "acceptance_forms": {
      "type": "object",
      "minProperties": 2,
      "maxProperties": 2,
      "additionalProperties": false,
      "properties": {
        "me": {"$ref": "#/$defs/acceptance_form"},
        "left": {"$ref": "#/$defs/acceptance_form"},
        "right": {"$ref": "#/$defs/acceptance_form"}
      }
    },
    "claimed_play_level": {"$ref": "#/$defs/claimed_play_level"},
    "decision_state_before_shortening": {"$ref": "#/$defs/decision_state"},
    "adjudicated_winner": {
      "type": "string",
      "enum": ["declarer", "defenders"]
    },
    "winner_basis": {"$ref": "#/$defs/winner_basis"},
    "continued_play_required": {"const": false},
    "remaining_points_assigned": {"const": false},
    "settlement_level_policy": {
      "type": "string",
      "enum": [
        "declared_and_unanimously_accepted_claimed_levels",
        "secured_observed_levels_only"
      ]
    }
  },
  "$defs": {
    "acceptance_form": {
      "type": "string",
      "enum": ["explicit", "unambiguous_conduct"]
    },
    "claimed_play_level": {
      "type": "string",
      "enum": ["simple", "schneider", "schwarz"]
    },
    "decision_state": {
      "type": "string",
      "enum": ["undecided", "declarer_already_won", "defenders_already_won"]
    },
    "winner_basis": {
      "type": "string",
      "enum": [
        "accepted_declarer_card_exposure",
        "preexisting_game_decision",
        "uncovered_overbid_requirement"
      ]
    },
    "settlement_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "game_end_kind",
        "outcome_source",
        "winner_basis",
        "decision_state_before_game_end",
        "claimed_play_level",
        "claimed_level_source",
        "declared_mandatory_schneider_applied",
        "declared_mandatory_schwarz_applied",
        "accepted_claimed_schneider_applied",
        "accepted_claimed_schwarz_applied",
        "achieved_schneider_applied",
        "achieved_schwarz_applied",
        "overbid_required_value_applied",
        "overbid_requirement_covered"
      ],
      "properties": {
        "game_end_kind": {"const": "declarer_card_exposure"},
        "outcome_source": {
          "type": "string",
          "enum": ["adjudicated", "preexisting_game_decision"]
        },
        "winner_basis": {"$ref": "#/$defs/winner_basis"},
        "decision_state_before_game_end": {"$ref": "#/$defs/decision_state"},
        "claimed_play_level": {"$ref": "#/$defs/claimed_play_level"},
        "claimed_level_source": {"const": "unanimous_defender_acceptance"},
        "declared_mandatory_schneider_applied": {"type": "boolean"},
        "declared_mandatory_schwarz_applied": {"type": "boolean"},
        "accepted_claimed_schneider_applied": {"type": "boolean"},
        "accepted_claimed_schwarz_applied": {"type": "boolean"},
        "achieved_schneider_applied": {"type": "boolean"},
        "achieved_schwarz_applied": {"type": "boolean"},
        "overbid_required_value_applied": {"type": "boolean"},
        "overbid_requirement_covered": {"type": "boolean"}
      }
    }
  }
}
