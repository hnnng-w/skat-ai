{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/skat-ai/training_dataset_output.schema.json",
  "title": "skat-ai training dataset output version 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_id",
    "dataset_version",
    "feature_generation_version",
    "target",
    "record_count",
    "sample_count",
    "partition_counts",
    "records"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "dataset_id": {"$ref": "#/$defs/stable_identifier"},
    "dataset_version": {"$ref": "#/$defs/stable_identifier"},
    "feature_generation_version": {"const": 1},
    "target": {"const": "actual_card_played"},
    "partition_policy": {
      "$ref": "https://example.local/skat-ai/dataset_partition_policy.schema.json"
    },
    "record_count": {"type": "integer", "minimum": 1},
    "sample_count": {"type": "integer", "minimum": 30},
    "partition_counts": {"$ref": "#/$defs/partition_counts"},
    "records": {
      "type": "array",
      "items": {"$ref": "#/$defs/record"},
      "minItems": 1
    }
  },
  "$defs": {
    "stable_identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\s)(?:[\\s\\S]*\\S)?$"
    },
    "card": {
      "type": "string",
      "pattern": "^[CSHD](A|10|K|Q|J|9|8|7)$"
    },
    "card_array": {
      "type": "array",
      "items": {"$ref": "#/$defs/card"},
      "uniqueItems": true
    },
    "relative_player": {
      "type": "string",
      "enum": ["me", "left", "right"]
    },
    "side": {
      "type": "string",
      "enum": ["declarer", "defenders"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "source_name"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "online_platform",
            "manual_entry",
            "imported_file",
            "synthetic",
            "other"
          ]
        },
        "source_name": {"$ref": "#/$defs/stable_identifier"},
        "source_record_id": {"$ref": "#/$defs/stable_identifier"},
        "collected_at": {
          "allOf": [
            {"$ref": "#/$defs/stable_identifier"},
            {"type": "string", "format": "date-time"}
          ]
        },
        "notes": {"$ref": "#/$defs/stable_identifier"}
      }
    },
    "partition_count": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_count", "sample_count"],
      "properties": {
        "record_count": {"type": "integer", "minimum": 0},
        "sample_count": {"type": "integer", "minimum": 0}
      }
    },
    "partition_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train", "validation", "test"],
      "properties": {
        "train": {"$ref": "#/$defs/partition_count"},
        "validation": {"$ref": "#/$defs/partition_count"},
        "test": {"$ref": "#/$defs/partition_count"}
      }
    },
    "relative_play": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player", "card"],
      "properties": {
        "player": {"$ref": "#/$defs/relative_player"},
        "card": {"$ref": "#/$defs/card"}
      }
    },
    "completed_trick": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trick_number",
        "plays",
        "winner",
        "winner_side",
        "trick_points"
      ],
      "properties": {
        "trick_number": {"type": "integer", "minimum": 1, "maximum": 10},
        "plays": {
          "type": "array",
          "items": {"$ref": "#/$defs/relative_play"},
          "minItems": 3,
          "maxItems": 3
        },
        "winner": {"$ref": "#/$defs/relative_player"},
        "winner_side": {"$ref": "#/$defs/side"},
        "trick_points": {"type": "integer", "minimum": 0, "maximum": 33}
      }
    },
    "declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hand_game",
        "ouvert",
        "schneider_announced",
        "schwarz_announced",
        "matadors",
        "bid_value"
      ],
      "properties": {
        "hand_game": {"type": "boolean"},
        "ouvert": {"type": "boolean"},
        "schneider_announced": {"type": "boolean"},
        "schwarz_announced": {"type": "boolean"},
        "matadors": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 11
        },
        "bid_value": {"type": "integer", "minimum": 1}
      }
    },
    "opponent_hand_size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player", "remaining_card_count"],
      "properties": {
        "player": {"type": "string", "enum": ["left", "right"]},
        "remaining_card_count": {"type": "integer", "minimum": 0, "maximum": 10}
      }
    },
    "exposed_cards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player", "cards"],
      "properties": {
        "player": {"$ref": "#/$defs/relative_player"},
        "cards": {
          "$ref": "#/$defs/card_array",
          "maxItems": 10
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "information_policy",
        "game_type",
        "declaration",
        "acting_position",
        "acting_side",
        "own_hand",
        "legal_cards",
        "current_trick",
        "completed_tricks",
        "declarer_trick_points",
        "defender_trick_points",
        "opponent_hand_sizes",
        "skat_visibility",
        "known_skat_cards",
        "public_exposed_cards"
      ],
      "properties": {
        "information_policy": {"const": "decision_time"},
        "game_type": {
          "type": "string",
          "enum": ["clubs", "spades", "hearts", "diamonds", "grand", "null"]
        },
        "declaration": {"$ref": "#/$defs/declaration"},
        "acting_position": {
          "type": "string",
          "enum": ["forehand", "middlehand", "rearhand"]
        },
        "acting_side": {"$ref": "#/$defs/side"},
        "own_hand": {
          "$ref": "#/$defs/card_array",
          "minItems": 1,
          "maxItems": 10
        },
        "legal_cards": {
          "$ref": "#/$defs/card_array",
          "minItems": 1,
          "maxItems": 10
        },
        "current_trick": {
          "type": "array",
          "items": {"$ref": "#/$defs/relative_play"},
          "maxItems": 2
        },
        "completed_tricks": {
          "type": "array",
          "items": {"$ref": "#/$defs/completed_trick"},
          "maxItems": 9
        },
        "declarer_trick_points": {"type": "integer", "minimum": 0, "maximum": 120},
        "defender_trick_points": {"type": "integer", "minimum": 0, "maximum": 120},
        "opponent_hand_sizes": {
          "type": "array",
          "items": {"$ref": "#/$defs/opponent_hand_size"},
          "minItems": 2,
          "maxItems": 2
        },
        "skat_visibility": {
          "type": "string",
          "enum": ["unknown", "known_to_declarer"]
        },
        "known_skat_cards": {
          "$ref": "#/$defs/card_array",
          "maxItems": 2
        },
        "public_exposed_cards": {
          "type": "array",
          "items": {"$ref": "#/$defs/exposed_cards"},
          "maxItems": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_id",
        "dataset_version",
        "record_id",
        "source_game_id",
        "partition",
        "decision_index",
        "trick_number",
        "play_index",
        "acting_player_id",
        "acting_seat",
        "acting_side",
        "provenance"
      ],
      "properties": {
        "dataset_id": {"$ref": "#/$defs/stable_identifier"},
        "dataset_version": {"$ref": "#/$defs/stable_identifier"},
        "record_id": {"$ref": "#/$defs/stable_identifier"},
        "source_game_id": {"$ref": "#/$defs/stable_identifier"},
        "source_played_at": {"type": "string", "format": "date-time"},
        "partition": {"type": "string", "enum": ["train", "validation", "test"]},
        "decision_index": {"type": "integer", "minimum": 1, "maximum": 30},
        "trick_number": {"type": "integer", "minimum": 1, "maximum": 10},
        "play_index": {"type": "integer", "minimum": 1, "maximum": 3},
        "acting_player_id": {"$ref": "#/$defs/stable_identifier"},
        "acting_seat": {
          "type": "string",
          "enum": ["forehand", "middlehand", "rearhand"]
        },
        "acting_side": {"$ref": "#/$defs/side"},
        "provenance": {"$ref": "#/$defs/provenance"}
      }
    },
    "label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "card"],
      "properties": {
        "target": {"const": "actual_card_played"},
        "card": {"$ref": "#/$defs/card"}
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_id", "metadata", "features", "label"],
      "properties": {
        "sample_id": {"$ref": "#/$defs/stable_identifier"},
        "metadata": {"$ref": "#/$defs/metadata"},
        "features": {"$ref": "#/$defs/features"},
        "label": {"$ref": "#/$defs/label"}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "partition",
        "provenance",
        "source_game_id",
        "historical_game",
        "sample_count",
        "samples"
      ],
      "properties": {
        "record_id": {"$ref": "#/$defs/stable_identifier"},
        "partition": {"type": "string", "enum": ["train", "validation", "test"]},
        "provenance": {"$ref": "#/$defs/provenance"},
        "source_game_id": {"$ref": "#/$defs/stable_identifier"},
        "source_played_at": {"type": "string", "format": "date-time"},
        "historical_game": {
          "$ref": "https://example.local/skat-ai/historical_game.schema.json"
        },
        "sample_count": {"const": 30},
        "samples": {
          "type": "array",
          "items": {"$ref": "#/$defs/sample"},
          "minItems": 30,
          "maxItems": 30
        }
      }
    }
  }
}
